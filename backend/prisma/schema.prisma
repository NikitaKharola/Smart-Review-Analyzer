// Prisma schema — updated for Week 6.
//
// Database choice: PostgreSQL, hosted by Supabase.
// Why: our data (users, reviews) is structured with fixed fields and a
// clear relationship between a review and the user who wrote it — a
// relational model fits better than a flexible document store here.
//
// Change from Week 5: user sign-in/sign-up is no longer handled by
// Supabase Auth. We now own our own "users" table, with bcrypt-hashed
// passwords and JWTs issued by our own backend. Supabase is still just
// our Postgres host — nothing more.
//
// Change for OAuth (this update):
// - `password` is now optional — Google-only users never set one.
// - `provider` / `providerId` record how the account was created and,
//   for OAuth accounts, the Google user id, so a login can be matched
//   back to the right row without relying on password auth at all.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique
  password   String?
  fullName   String?  @map("full_name")
  provider   String   @default("local") @map("provider")
  providerId String?  @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at")

  reviews    Review[]

  @@map("users")
}

model Review {
  id             Int      @id @default(autoincrement())
  username       String
  reviewText     String   @map("review_text")
  rating         Int
  sentiment      String?
  theme          String?
  confidence     Decimal? @db.Decimal(5, 2)
  positivePoints String?  @map("positive_points")
  negativePoints String?  @map("negative_points")
  suggestedReply String?  @map("suggested_reply")

  // Link to the user who submitted this review. Still nullable so
  // guest submissions (if you support them) keep working.
  userId         String?  @map("user_id") @db.Uuid
  user           User?    @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reviews")
}
