PORT=5000
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Prisma connects to your Supabase Postgres database directly.
# Find this in Supabase: Project Settings -> Database -> Connection string -> URI
# (use the "Connection pooling" string if deploying to a serverless host)
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="your_pooled_postgres_connection_string_here"
DIRECT_URL="your_direct_postgres_connection_string_here"
JWT_SECRET=your_own_random_jwt_secret_here

FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Get a free token at https://huggingface.co/settings/tokens
# (Fine-grained token with "Make calls to Inference Providers" permission)
HF_API_KEY=your_huggingface_token_here